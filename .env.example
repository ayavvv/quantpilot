# QuantPilot Configuration
# Copy to .env and fill in your values

# ============================================================
# Data Paths
# ============================================================
DATA_DIR=~/quantpilot_data
# DATA_DIR=/data                    # Docker default

# ============================================================
# NAS Data Source (for distributed deployment)
# Leave empty for single-machine setup
# ============================================================
NAS_HOST=
NAS_USER=
NAS_QLIB_PATH=/qlib_data
SSH_KEY=~/.ssh/id_ed25519

# ============================================================
# Collector
# ============================================================
# Baostock: no credentials needed (free, socket-based)
CRON_TIME=16:30

# Futu OpenD (optional, for HK/US markets)
FUTU_HOST=localhost
FUTU_PORT=11111

# Extra codes (US ETFs, macro indices via Yahoo Finance)
# EXTRA_CODES=US.SPY,US.QQQ

# ============================================================
# Inference
# ============================================================
QLIB_DATA_DIR=/qlib_data
MODEL_DIR=/app/models
SIGNAL_DIR=/data/signals
MARKET=sh
# MODEL_NAME=lightgbm_sh_latest.pkl

# ============================================================
# Trader
# ============================================================
# FUTU_HOST=localhost
# FUTU_PORT=11111
# FUTU_RSA_KEY=/path/to/futu_rsa_private_key.pem
# Host `scripts/run_trade.sh` uses the host path directly; `docker-compose.mac.yml`
# mounts this file into the trader container automatically when it is configured.
# Host `scripts/run_trade.sh` overrides this to $DATA_DIR/signals/pred_sh_latest.pkl
# unless you call `python -m trader.trade_daily` directly.
PRED_PATH=/models/pred_sh.pkl
TOP_N=5
HOLD_BONUS=0.05
STOP_LOSS_PCT=-0.08
# 绑定指定模拟账户。0 表示使用 OpenD 返回的第一个模拟账户。
FUTU_SIM_ACC_ID=0
# 模板默认保持空跑；生产调度可在 .env 中改为 false。
DRY_RUN=true
# false 时，若 OpenD 判断沪深均未开市，则强制自动切到 dry-run。
ALLOW_OFF_HOURS_TRADING=false

# ============================================================
# Reporter (SMTP email)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
REPORT_TO=
REPORT_FROM=

# ============================================================
# Weekly Trainer (Docker defaults are set in docker-compose.yml)
# ============================================================
# STRATEGY_DIR=/app
# MODELS_DIR=/data/models
# OUTPUT_DIR=/data/output
# TRADE_PRED_PATH=/data/models/pred_sh.pkl
# NAS_HOST=                     # Empty = skip NAS sync (use mounted data)
# NAS_USER=
# NAS_QLIB_PATH=/qlib_data
EMAIL_FROM=
EMAIL_TO=
